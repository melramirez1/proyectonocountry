# --- INFRASTRUCTURE (Local Docker) ---
# Database connection string for Prisma ORM
DATABASE_URL="postgresql://admin:secret_password_123@localhost:5432/nocountry_db"

# --- SECURITY ---
# Secret key for JWT authentication tokens
JWT_SECRET=change_this_secret_key_in_production

# --- EXTERNAL INTEGRATIONS ---
# API credentials for media and image hosting
CLOUDINARY_URL=
YOUTUBE_API_KEY=

# --- SERVER CONFIG ---
PORT=3000